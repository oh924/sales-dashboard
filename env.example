# ============================================
# ローカル開発
# ============================================
# PostgreSQL (Docker または Neon 無料プランなど)
# DATABASE_URL="postgresql://user:password@localhost:5432/sales_dashboard"
# DIRECT_URL="postgresql://user:password@localhost:5432/sales_dashboard"

# ============================================
# 本番 Vercel + Prisma Postgres
# ============================================
# Prisma コンソール (console.prisma.io) で作成した DB の接続情報
# DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"
# DIRECT_URL="postgresql://USER:PASS@HOST:PORT/DBNAME?schema=public"

# ============================================
# NextAuth
# ============================================
NEXTAUTH_SECRET="your-random-secret-32chars-or-more"
NEXTAUTH_URL="https://your-app.vercel.app"
